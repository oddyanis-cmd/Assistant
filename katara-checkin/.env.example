# Copy to .env and adjust. Every variable is prefixed with KATARA_.

# ── Database ───────────────────────────────────────────────────────────────
KATARA_DATABASE_URL=sqlite:///./katara_checkin.db

# ── Face engine ────────────────────────────────────────────────────────────
KATARA_FACE_ENGINE=auto
KATARA_INSIGHTFACE_MODEL=buffalo_l
KATARA_DET_SIZE=640

# ── Decision thresholds (the accuracy / strictness knobs) ──────────────────
# Raise ACCEPT_THRESHOLD to make false accepts rarer (and rejects more common).
# Calibrate these for YOUR camera & lighting with scripts/calibrate.py.
KATARA_ACCEPT_THRESHOLD=0.45
KATARA_DECISION_MARGIN=0.10
KATARA_MIN_DET_SCORE=0.55

# ── Liveness / anti-spoofing ───────────────────────────────────────────────
KATARA_REQUIRE_LIVENESS=true
KATARA_LIVENESS_MIN_MOTION=6.0

# ── CRM webhook (leave blank to run in local test mode) ────────────────────
KATARA_CRM_WEBHOOK_URL=
KATARA_CRM_API_KEY=
KATARA_CRM_TIMEOUT_SECONDS=8
