# ============================================================
# Shiny Beauty Center — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing secrets.
# ============================================================

# ------ Supabase (required for auth + DB) ------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------ Tap Payments (Phase 3) ------
TAP_SECRET_KEY=sk_live_xxxxx
TAP_PUBLIC_KEY=pk_live_xxxxx
TAP_WEBHOOK_SECRET=whsec_xxxxx

# ------ WhatsApp / WATI Notifications (Phase 4) ------
WATI_API_ENDPOINT=https://live-mt-server.wati.io/xxxxx
WATI_ACCESS_TOKEN=your-wati-token-here
# Alternative: Twilio
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886

# ------ Feature flags ------
# Set to "true" to enable; keep "false" until the phase is ready.
NEXT_PUBLIC_PAYMENTS_ENABLED=false
NEXT_PUBLIC_NOTIFICATIONS_ENABLED=false

# ------ App ------
NEXT_PUBLIC_APP_URL=http://localhost:3000
