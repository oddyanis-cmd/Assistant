# ============================================================
# Shiny Beauty Center — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing secrets.
# ============================================================

# ------ Supabase (required for auth + DB) ------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------ Tap Payments (Phase 5) ------
# Secret keys — server only; NEVER prefix with NEXT_PUBLIC_
TAP_SECRET_KEY=sk_live_xxxxx
TAP_WEBHOOK_SECRET=whsec_xxxxx
# Charge mode: "full" (default) charges full price; "deposit" charges TAP_DEPOSIT_PERCENT %
TAP_CHARGE_MODE=full
TAP_DEPOSIT_PERCENT=30
# Currency (ISO 4217); Qatar = QAR
TAP_CURRENCY=QAR
# Publishable key — safe for client-side (used by Tap.js if integrated)
NEXT_PUBLIC_TAP_PUBLIC_KEY=pk_live_xxxxx

# ------ WhatsApp / WATI Notifications (Phase 5) ------
# WATI is the preferred WhatsApp Business API provider for Gulf markets.
# Server-only — do NOT prefix with NEXT_PUBLIC_.
WATI_API_ENDPOINT=https://live-mt-server.wati.io/123456
WATI_ACCESS_TOKEN=your-wati-access-token-here

# ------ Email Notifications (Phase 5) ------
# Resend (preferred — sign up at resend.com):
RESEND_API_KEY=re_xxxxxxxxxxxx
# Sender address in RFC 5322 format:
EMAIL_FROM=Shiny Beauty Center <hello@shinybeauty.com>
# Alternative: SMTP (e.g. SendGrid, Mailgun, Postmark SMTP relay)
# If RESEND_API_KEY is set it takes precedence over SMTP_*.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxxxxxxxxxx

# ------ Cron / Reminders (Phase 5) ------
# A random secret that Vercel sends as "Authorization: Bearer <secret>" on cron calls.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-random-hex-string

# ------ Feature flags ------
# Set to "true" to enable; keep "false" until the phase is ready.
NEXT_PUBLIC_PAYMENTS_ENABLED=false
NEXT_PUBLIC_NOTIFICATIONS_ENABLED=false

# ------ App ------
NEXT_PUBLIC_APP_URL=http://localhost:3000
