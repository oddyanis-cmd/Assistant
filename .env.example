# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp Business Cloud API
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_ACCESS_TOKEN=EAAxxxxxx
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_OWNER_PHONE=34600000000   # Your phone number (no + prefix)

# Meta Graph API — for Facebook Page and Instagram posts
META_PAGE_ID=1234567890
META_PAGE_ACCESS_TOKEN=EAAxxxxxx
META_INSTAGRAM_ACCOUNT_ID=1234567890

# Meta Ads
META_ADS_ACCOUNT_ID=act_1234567890
META_ADS_ACCESS_TOKEN=EAAxxxxxx

# Gmail OAuth2 — generate at console.cloud.google.com
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/gmail/callback

# LinkedIn OAuth2 — generate at developer.linkedin.com
LINKEDIN_CLIENT_ID=xxxx
LINKEDIN_CLIENT_SECRET=xxxx
LINKEDIN_REDIRECT_URI=https://your-domain.com/auth/linkedin/callback

# Database (SQLite for local, PostgreSQL for production)
DATABASE_URL=sqlite:///./assistant.db

# App
APP_BASE_URL=https://your-domain.com

# Digital Waiver form (Katara Club) — see DEPLOYMENT.md for the full guide
WAIVER_RECIPIENT_EMAIL=Reception@Katara.club
WAIVER_STORAGE_DIR=./waiver_storage

# Microsoft 365 (Graph) — emails reception AND saves signed PDFs into your 365
MS365_TENANT_ID=
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=
MS365_SENDER=Reception@Katara.club
MS365_SEND_EMAIL=true
MS365_SAVE_TO_DRIVE=true
MS365_SAVE_FOLDER=Katara Club Waivers
MS365_SHAREPOINT_SITE=

# Optional SMTP fallback (only used if Microsoft 365 above is not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
