# ── Database ────────────────────────────────────────────────────────
# Neon / Supabase pooled connection (used by Prisma at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct non-pooled connection (used by Prisma migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Local Docker dev:
# docker run --name belza-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=belza -p 5432:5432 -d postgres:16
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/belza?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/belza?schema=public"

# ── Auth (NextAuth v5 / Auth.js) ─────────────────────────────────────
AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"          # prod: https://yourdomain.com

# ── Seed credentials (used by prisma/seed.ts only, remove after first seed) ──
ADMIN_EMAIL="owner@salon.com"
ADMIN_PASSWORD="change-me-strong"

# ── Payments (Stripe) ───────────────────────────────────────────────
PAYMENTS_ENABLED="false"                  # set "true" only after webhook works
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Email ────────────────────────────────────────────────────────────
EMAIL_PROVIDER="resend"                   # resend | smtp
RESEND_API_KEY="re_..."
EMAIL_FROM="Belza Salon <bookings@yourdomain.com>"

# SMTP fallback (optional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# ── Misc ─────────────────────────────────────────────────────────────
CRON_SECRET="run: openssl rand -base64 32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
