# ────────────────────────────────────────────────────────────────────────────
# Katara Club — Digital Waiver System configuration
# Copy this file to ".env" and fill in the values, then: docker compose up -d
# ────────────────────────────────────────────────────────────────────────────

# Public URL where this system is reachable. The reception QR code points here,
# so it MUST be an address members' phones can open (your domain or server IP).
APP_BASE_URL=https://waiver.katara.club

# Where signed forms are emailed.
WAIVER_RECIPIENT_EMAIL=Reception@katara.club

# Protect the management pages (/waiver/admin, /status, /pdf) — they contain
# members' personal data. Set a strong password before going live.
ADMIN_USER=reception
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── Google Workspace (Drive + Gmail) — see DEPLOYMENT-GOOGLE.md ─────────────
# Store signed PDFs in a Google Drive (Shared Drive) folder and email via Gmail.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DELEGATED_SENDER=Reception@katara.club
GOOGLE_SAVE_TO_DRIVE=true
GOOGLE_SEND_EMAIL=true
# Service-account key: inline JSON (easiest on Cloud Run) OR a file path.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=

# ── Microsoft 365 (alternative) ─────────────────────────────────────────────
# One Azure app registration handles BOTH emailing reception and saving a copy
# into your Microsoft 365. See DEPLOYMENT.md for the 5-minute setup.
MS365_TENANT_ID=00000000-0000-0000-0000-000000000000
MS365_CLIENT_ID=00000000-0000-0000-0000-000000000000
MS365_CLIENT_SECRET=your-client-secret-value

# Mailbox / OneDrive the system sends and saves from (usually reception itself).
MS365_SENDER=Reception@katara.club

# Toggle features
MS365_SEND_EMAIL=true        # email the signed PDF to reception
MS365_SAVE_TO_DRIVE=true     # archive a copy into Microsoft 365

# Where the archived copies are stored.
MS365_SAVE_FOLDER=Katara Club Waivers
# Leave SHAREPOINT_SITE blank to save in the sender's OneDrive, OR set it to a
# SharePoint site to use a shared document library, e.g.:
#   MS365_SHAREPOINT_SITE=katara.sharepoint.com/sites/Reception
MS365_SHAREPOINT_SITE=

# ── SMTP fallback (optional) ────────────────────────────────────────────────
# Only used if Microsoft 365 above is not configured. For M365 SMTP this is
# smtp.office365.com:587 and requires "SMTP AUTH" enabled on the mailbox.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Katara Club <Reception@katara.club>
